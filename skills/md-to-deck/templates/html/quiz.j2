{% import "_macros.j2" as m %}
{% call m.stage(section, title, highlights) %}
<div class="quiz{{ ' quiz-split' if image and image[1] else '' }}">
<div class="quiz-body">
<p class="quiz-q">{{ question }}</p>
{% if options %}
<ol class="quiz-opts">
{% for o in options %}
{% if loop.index0 == correct_index %}
{# the correct choice is a Reveal *custom* fragment: it stays on screen but restyles itself
   (accent fill + check) on the same next-nav step that fades in the answer panel. #}
<li class="qopt correct fragment custom" data-fragment-index="0">{{ o }}</li>
{% else %}
<li class="qopt">{{ o }}</li>
{% endif %}
{% endfor %}
</ol>
{% endif %}
<div class="quiz-ans fragment fade-up" data-fragment-index="0">
<span class="quiz-lab">{{ icon("check_circle") }}{{ answer_label }}</span>
<p class="quiz-a">{{ answer }}</p>
{% if explanation %}<p class="quiz-exp">{{ explanation }}</p>{% endif %}
</div>
</div>
{% if image and image[1] %}<div class="quiz-media">{{ embed(image[0], image[1]) }}</div>{% endif %}
</div>
{% endcall %}
