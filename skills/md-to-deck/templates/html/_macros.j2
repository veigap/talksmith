{# Shared chrome. Every content template wraps its body in `stage(s)`, where `s` is the
   slide-model slide — so the macros read section/title/highlights/reveal/lead off it directly. #}
{% macro header(s) %}
{% if s.section %}<span class="pill">{{ s.section }}</span>{% endif %}
{% if s.title %}<h2 class="stitle">{{ s.title }}</h2>{% endif %}
{% endmacro %}
{# `aside: {image, side}` → a full-bleed image column on that edge (default right), reinforcing
   the content visually. Available to every stage-based slide; the stage's side padding keeps the
   head and body clear of it. #}
{% macro stage(s) %}
<div class="stage{{ (' aside-' + (s.aside.side or 'right')) if s.aside else '' }}">
{% if s.aside %}<div class="sasi">{{ embed_img(s.aside.image) }}</div>{% endif %}
<div class="shead">{{ header(s) }}</div><div class="cbody"><div class="cfit">{{ caller() }}
{% if s.highlights %}<div class="highlights{{ frag(s) }}">{% for h in s.highlights %}<div class="highlight {{ h.kind }}">{{ icon(h.icon) }}<p>{% if h.label %}<b>{{ h.label }}</b>: {% endif %}{{ h.body }}</p></div>{% endfor %}</div>{% endif %}
</div></div></div>
{% endmacro %}
{# Enumeration items appear one at a time (Reveal fragments) by default; `reveal: together`
   opts out and shows them all at once. Negated on purpose: an unrecognized value animates,
   which is the default anyone wants — the opt-in form failed silently on every typo.
   Pass the enclosing `loop` for per-item enumerations: the FIRST item never gets `fragment`,
   so it is on screen the moment the slide is presented (an empty stage that needs a keypress
   to show anything reads as a broken slide) — only items 2..N animate in. Group containers
   (e.g. highlights) call `frag(s)` with no loop and stay a single fragment as before. #}
{% macro frag(s, loop=None) %}{{ '' if s.reveal == 'together' or (loop and loop.first) else ' fragment fade-up' }}{% endmacro %}
{% macro lead(s) %}{% if s.lead %}<p class="lead">{{ s.lead }}</p>{% endif %}{% endmacro %}
