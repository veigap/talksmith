{% import "_macros.j2" as m %}
{% call m.stage(section, title, highlights) %}
{% if body %}<p class="lead">{{ body[0] }}</p>{% endif %}
{% if labeled %}
<div class="numrow">
{% for it in items %}
<div class="ncard"><div class="strip">{{ loop.index }}</div><div class="nbody"><h4>{{ it.label }}</h4><p>{{ it.body }}</p></div></div>
{% endfor %}
</div>
{% else %}
<div class="steps">
{% for it in items %}
<div class="steprow"><span class="stepn">{{ loop.index }}</span><p>{{ it.body }}</p></div>
{% endfor %}
</div>
{% endif %}
{% endcall %}
