{% import "_macros.j2" as m %}
{% call m.stage(s) %}
{% if s.image %}
<div class="procgrid"><div class="procmain">
{% endif %}
{{ m.lead(s) -}}
{% if s.image %}
<div class="procsteps">
{% for st in s.steps %}
<div class="steprow"><span class="stepn">{{ loop.index }}</span><p>{% if st.label %}<b>{{ st.label }}</b>: {% endif %}{{ st.body }}</p></div>
{% endfor %}
</div>
{% elif s.steps | selectattr('label') | first %}
{# any step carrying a label → the labelled numbered-card row #}
<div class="numrow">
{% for st in s.steps %}
<div class="ncard"><div class="strip">{{ loop.index }}</div><div class="nbody"><h4>{{ st.label }}</h4><p>{{ st.body }}</p></div></div>
{% endfor %}
</div>
{% else %}
<div class="steps">
{% for st in s.steps %}
<div class="steprow"><span class="stepn">{{ loop.index }}</span><p>{{ st.body }}</p></div>
{% endfor %}
</div>
{% endif %}
{% if s.image %}
</div><div class="procmedia">{{ embed_img(s.image) }}</div></div>
{% endif %}
{% endcall %}
