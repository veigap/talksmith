{% import "_macros.j2" as m %}
{% call m.stage(s) %}
<div class="proscons">
<div class="pccol pc-pro">{{ icon('verified') }}<h3>{{ s.pro_label or L.pros }}</h3><p>{{ s.pros | join(' · ') }}</p></div>
<div class="pccol pc-con">{{ icon('dangerous') }}<h3>{{ s.con_label or L.cons }}</h3><p>{{ s.cons | join(' · ') }}</p></div>
</div>
{% endcall %}
