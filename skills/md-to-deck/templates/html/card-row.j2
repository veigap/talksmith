{% import "_macros.j2" as m %}
{% call m.stage(section, title) %}
{% if body %}<p class="lead">{{ body[0] }}</p>{% endif %}
<div class="cardrow">
{% for it in items %}
<div class="rcard">{{ chip(icon_for(it.label, it.body)) }}<h3>{{ it.label }}</h3><p>{{ it.body }}</p></div>
{% endfor %}
</div>
{% endcall %}
