{% import "_macros.j2" as m %}
{% call m.stage(section, title, highlights) %}
{% if body %}<p class="lead">{{ body[0] }}</p>{% endif %}
<div class="cardrow">
{% for it in items %}
<div class="rcard{{ ' fragment fade-up' if reveal == 'sequential' else '' }}">{{ chip(it.icon) }}<h3>{{ it.label }}</h3><p>{{ it.body }}</p></div>
{% endfor %}
</div>
{% endcall %}
