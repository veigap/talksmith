{% import "_macros.j2" as m %}
{% call m.stage(section, title) %}
{% if body %}<p class="lead">{{ body[0] }}</p>{% endif %}
<div class="iconlist">
{% for it in items %}
<div class="ilrow">{{ icon(icon_for(it.label, it.body)) }}<div><h4>{{ it.label }}</h4>{% if it.body %}<p>{{ it.body }}</p>{% endif %}</div></div>
{% endfor %}
</div>
{% endcall %}
