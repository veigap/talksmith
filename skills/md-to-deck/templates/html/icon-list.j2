{% import "_macros.j2" as m %}
{% call m.stage(section, title, highlights) %}
{% if body %}<p class="lead">{{ body[0] }}</p>{% endif %}
<div class="iconlist">
{% for it in items %}
<div class="ilrow{{ ' solo' if not it.body else '' }}{{ ' fragment fade-up' if reveal == 'sequential' else '' }}">{{ icon(it.icon) }}<div><h4>{{ it.label }}</h4>{% if it.body %}<p>{{ it.body }}</p>{% endif %}</div></div>
{% endfor %}
</div>
{% endcall %}
