{% import "_macros.j2" as m %}
{% macro citext(s) %}
<div class="citext">
{{ m.lead(s) -}}
{% if s.facts %}<ul class="cifacts">{% for f in labeled(s.facts) %}<li>{% if f.label %}<b>{{ f.label }}</b>: {% endif %}{{ f.body }}</li>{% endfor %}</ul>{% endif %}
</div>
{% endmacro %}
{% call m.stage(s) %}
{% if s.layout == 'image-top' %}
<div class="ci ci-top">{{ embed_img(s.image) }}{{ citext(s) }}</div>
{% else %}
<div class="ci">{{ citext(s) }}{{ embed_img(s.image) }}</div>
{% endif %}
{% endcall %}
